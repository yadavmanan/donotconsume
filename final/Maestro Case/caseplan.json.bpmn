      <bpmn:sequenceFlow id="edge_eventSubprocessExclusiveGateway-runTasksInclusiveGateway" sourceRef="eventSubprocessExclusiveGateway" targetRef="runTasksInclusiveGateway">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions?.caseExited?.exited != true) &amp;&amp; (vars.caseManagerDecisions?.tasksToRun != null &amp;&amp; vars.caseManagerDecisions?.tasksToRun.length &gt; 0)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="skipMessageEdge" sourceRef="noTasksToRunExclusiveGateway" targetRef="eventSubprocessEndEvent" />
      <bpmn:sequenceFlow id="sendMessageEdge" sourceRef="noTasksToRunExclusiveGateway" targetRef="SendCaseEndMessageEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions != null &amp;&amp; vars.caseManagerDecisions.caseResolution != null &amp;&amp; vars.caseManagerDecisions.caseResolution.type != null) ? vars.caseManagerDecisions.caseResolution.type == "completed" : false</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tr3Smvq9d_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tr3Smvq9d_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "recall_trigger_final" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tvFI5RD1H_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tvFI5RD1H_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "lot_tracing_final" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tkpf3yEX0_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tkpf3yEX0_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "kde_report_final" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tlyxnRecv_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tlyxnRecv_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "quarantineapi_final" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tIU4CzGH1_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tIU4CzGH1_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "notifychain" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tkPjb4GYZ_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tkPjb4GYZ_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "Wait for timer" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tJO3YZMsy_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tJO3YZMsy_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "Agent" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-unknownTaskFallbackEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="unknownTaskFallbackEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; !["recall_trigger_final","lot_tracing_final","kde_report_final","quarantineapi_final","notifychain","Wait for timer","Agent"].includes(task.taskName))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
    </bpmn:subProcess>
