ces","value":"=vars.traces","type":"object","description":"Complete contamination trace object for a recall or quarantine event. Expected format: a JSON object sourced from an upstream traceability workflow. Typical fields include contaminationType, traceabilityLotCode, urgency, recallClassEstimate, product, originFacility, productionDate, expiryDate, limsResults, statesAffected, totalUnitsAffected, supplyChainNodes, warehouseInventory, and criticalTrackingEvents. Use values exactly as provided, preserve units and identifiers, and treat missing or unknown fields as unavailable rather than inventing replacements.","additionalProperties":true,"required":true,"id":"vhyue8Jl7","var":"vhyue8Jl7","elementId":"Stage_9tRz3E-tIU4CzGH1"}],"outputs":[{"name":"Error","displayName":"Error","value":"error6","type":"jsonSchema","source":"=Error","_jsonSchema":{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}},"id":"error6","var":"error6","elementId":"Stage_9tRz3E-tIU4CzGH1","body":{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}},{"name":"summary","displayName":"summary","value":"summary2","type":"string","description":"Plain-language execution summary of the quarantine notification run. Expected format: 2-6 sentences. Derived from the input trace and tool results. Include the contamination type, lot code, urgency, and overall send outcome. Included on every successful or partially successful run.","source":"=summary","id":"summary2","var":"summary2","elementId":"Stage_9tRz3E-tIU4CzGH1"},{"name":"notificationCount","displayName":"notificationCount","value":"notificationCount","type":"integer","description":"Number of quarantine notification emails the agent attempted to send, counted from sup