          <uipath:inputOutput id="fsma204KdeData" name="fsma204_kde_data" type="jsonSchema" subType="object" elementId="Stage_lhUjF4-tkpf3yEX0"><![CDATA[{"type":"array","description":"FSMA Section 204 KDE spreadsheet records in JSON format. Use INCOMPLETE for any mandatory field that cannot be found.","items":{"type":"object","properties":{"traceabilityLotCode":{"type":"string"},"productDescription":{"type":"string"},"quantity":{"type":"string"},"unitOfMeasure":{"type":"string"},"cteType":{"type":"string","description":"One of: harvesting, cooling, packing, shipping, receiving"},"cteDate":{"type":"string"},"cteLocation":{"type":"string"},"referenceDocumentNumber":{"type":"string"},"firstReceiverInfo":{"type":"string"}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
