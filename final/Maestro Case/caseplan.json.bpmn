          <uipath:inputOutput id="notifications" name="notifications" type="jsonSchema" subType="object" elementId="Stage_9tRz3E-tIU4CzGH1"><![CDATA[{"type":"array","description":"Per-recipient notification results produced from the trace. Expected format: array of objects, one per supply-chain node considered. Values come from the input trace, generated notification text, and tool outcomes. Include when the trace contains supplyChainNodes, even if some are skipped. Possible values: empty array or populated list.","items":{"type":"object","properties":{"nodeId":{"type":"string","description":"Supply-chain node identifier from the trace."},"nodeName":{"type":"string","description":"Supply-chain node name from the trace."},"recipientType":{"type":"string","description":"Message audience selected by the agent for the notification. Possible values: warehouse, retailer, distributor, public, other."},"email":{"type":"string","description":"Recipient email address used or intended for the notification."},"subject":{"type":"string","description":"Email subject generated for this notification."},"body":{"type":"string","description":"Email body generated for this notification."},"status":{"type":"string","description":"Processing result for this node. Possible values: sent, skipped, failed."},"reason":{"type":"string","description":"Short explanation for skipped or failed outcomes, or a brief success note."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
