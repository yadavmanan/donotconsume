tEventType == \"CaseEntered\" || vars.EventSubProcessLatestEventType == \"TaskCompleted\") ? false : true }, \"state\": { ...vars.caseState, \"vars\": { \"recall_trigger_final\": { \"Error\": (vars.error2), \"content\": (vars.content), \"lotcodes\": (vars.lotcodes) }, \"lot_tracing_final\": { \"Error\": (vars.error3), \"totalLotsRequested\": (vars.totalLotsRequested), \"successfulLots\": (vars.successfulLots), \"failedLotCodes\": (vars.failedLotCodes), \"totalUnitsAffected\": (vars.totalUnitsAffected), \"traces\": (vars.traces) }, \"kde_report_final\": { \"Error\": (vars.error4), \"fsma204_kde_data\": (vars.fsma204KdeData), \"fda_cover_letter\": (vars.fdaCoverLetter), \"internal_recall_summary\": (vars.internalRecallSummary), \"incomplete_fields\": (vars.incompleteFields), \"content\": (vars.content2) }, \"quarantineapi_final\": { \"Error\": (vars.error5), \"content\": (vars.content3), \"quarantined\": (vars.quarantined), \"quarantineResults\": (vars.quarantineResults), \"notFoundLotcodes\": (vars.notFoundLotcodes), \"matchedInventoryIds\": (vars.matchedInventoryIds), \"summary\": (vars.summary) }, \"notifychain\": { \"Error\": (vars.error6), \"summary\": (vars.summary2), \"notificationCount\": (vars.notificationCount), \"sentCount\": (vars.sentCount), \"notifications\": (vars.notifications) }, \"Wait for timer\": {  }, \"Agent\": { \"Error\": (vars.error7), \"content\": (vars.content4) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) }, \"APIEvent\": (vars.mainEventSubprocessResponse.apiEvent) } } })"}]]></uipath:input>
