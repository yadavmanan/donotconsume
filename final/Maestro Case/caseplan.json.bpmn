          <uipath:inputOutput id="incompleteFields" name="incomplete_fields" type="jsonSchema" subType="object" elementId="Stage_lhUjF4-tkpf3yEX0"><![CDATA[{"type":"array","description":"Mandatory KDE fields that were missing or could not be verified. Each item must have status INCOMPLETE.","items":{"type":"object","properties":{"recordReference":{"type":"string","description":"Best available reference such as lot code, CTE type/date, or source document."},"fieldName":{"type":"string","description":"Name of the missing mandatory KDE field."},"cteType":{"type":"string","description":"Related CTE type when known."},"status":{"type":"string","description":"Always INCOMPLETE."},"notes":{"type":"string","description":"Brief explanation of what source data is missing."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
